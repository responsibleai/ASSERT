# =============================================================================
# Document DLP AgentShield example for ASSERT.
# Copy this file to .env and fill in your values:
#
#   cp .env.example .env
#
# Then run from the ASSERT repo root:
#
#   p2m run --config examples/document_dlp_agent_shield/eval_config_unguarded.yaml
#   p2m run --config examples/document_dlp_agent_shield/eval_config_naive_prompt.yaml
#   p2m run --config examples/document_dlp_agent_shield/eval_config_guarded.yaml
# =============================================================================

# Azure OpenAI (used by both the agent under test AND every ASSERT pipeline stage
# whose model name starts with "azure/").
AZURE_API_KEY=
AZURE_API_BASE=https://<your-resource>.services.ai.azure.com
# AZURE_API_VERSION=2024-12-01-preview

# Override the agent's deployment name. Default: gpt-4o-mini.
# AGENT_MODEL=gpt-4o-mini

# Override the per-process SQLite DB the SQLite + email MCP servers share.
# Defaults to %TEMP%/document_dlp_assert_<pid>.db so concurrent eval workers
# do not stomp each other.
# DOCUMENT_DLP_SQLITE_DB=C:/tmp/document_dlp.db

# Override the guardrails YAML used by the guarded variant. Path may be
# absolute or relative to this directory. Useful for A/B testing alternative
# policies without code edits.
# P2M_GUARDRAILS_YAML=guardrails.yaml
