# =============================================================================
# 1. Foundry hosted agent (the target under test)
# =============================================================================

# Foundry project endpoint — auto-injected in hosted containers.
# Only set manually if running without `azd ai agent run`.
# Example: https://<resource>.services.ai.azure.com/api/projects/<project>
FOUNDRY_PROJECT_ENDPOINT=

# Model deployment name — must match a deployment in your Foundry project.
AZURE_AI_MODEL_DEPLOYMENT_NAME=gpt-5.4

# Deployed agent's Responses endpoint (printed by `azd deploy`).
# Read by auto_trace.py:chat_sync, the eval target.
FOUNDRY_AGENT_ENDPOINT=

# =============================================================================
# 2. ASSERT model auth (systematize / test generation / tester / judge)
# =============================================================================
# eval_config.yaml calls `azure/gpt-5.4` via LiteLLM for every pipeline stage.
# These calls are SEPARATE from the agent above and need their own Azure OpenAI
# credentials. Set a key + base, OR use Entra ID (AAD) auth.

# Azure OpenAI endpoint for the model that runs the eval pipeline.
# Example: https://your-resource.openai.azure.com/
AZURE_API_BASE=

# Option A: API key auth.
AZURE_API_KEY=

# Option B: Entra ID (AAD) auth instead of a key — requires
# `pip install -e ".[azure-aad]"` and the "Cognitive Services OpenAI User"
# role on the Azure OpenAI resource. Uncomment to force AAD even when
# AZURE_API_KEY is set:
# ASSERT_AZURE_USE_AAD=1
# Pin a specific user-assigned managed identity (optional):
# AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000