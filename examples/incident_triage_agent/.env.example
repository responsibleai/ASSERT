# Incident Triage Agent — local environment overrides
#
# This file layers on top of the repo-root .env (LiteLLM provider creds shared
# with all demos). It only needs to override demo-specific knobs.
#
# In the repo-root .env, you must define:
#   AZURE_API_KEY
#   AZURE_API_BASE       (e.g. https://<resource>.openai.azure.com)
#   AZURE_API_VERSION    (e.g. 2024-10-21)

# Model used by the agent's reasoning loop (LiteLLM provider/model spelling).
INCIDENT_TRIAGE_MODEL=azure/gpt-4o-mini

# Phoenix project name (optional — enables traces under a dedicated project
# in the local Phoenix UI at http://localhost:6006).
PHOENIX_PROJECT_NAME=incident-triage-agent
