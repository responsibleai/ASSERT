# Incident Triage Agent — local environment overrides
#
# This file layers on top of the repo-root .env (LiteLLM provider creds shared
# with all demos). It only needs to define keys specific to this demo or
# overrides for the model used by the agent.

# Model used by the agent's reasoning loop (LiteLLM provider/model spelling).
# The repo-root .env should already provide the AZURE_API_KEY / AZURE_API_BASE
# / AZURE_API_VERSION needed for the azure/* providers.
INCIDENT_TRIAGE_MODEL=azure/gpt-5.4-mini

# Model used by AgentShield's "manager judge" HumanResolver in eval mode.
# This LLM decides whether to approve or deny each gated tool call. See
# agent_guarded.py for the prompt template.
INCIDENT_TRIAGE_MANAGER_JUDGE_MODEL=azure/gpt-5.4-mini

# Phoenix project name (optional — enables traces under a dedicated project
# in the local Phoenix UI at http://localhost:6006).
PHOENIX_PROJECT_NAME=incident-triage-agent
