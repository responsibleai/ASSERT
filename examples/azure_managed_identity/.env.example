# Azure OpenAI endpoint — always required.
AZURE_API_BASE=https://your-resource.openai.azure.com/

# Force AAD even if AZURE_API_KEY is also defined elsewhere in the shell.
ASSERT_AZURE_USE_AAD=1

# Optional: pin a specific user-assigned managed identity when several are
# attached to the workload. Otherwise DefaultAzureCredential probes its
# full chain (env vars, MI, az login, etc.).
# AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000

# Intentionally NOT set:
#   AZURE_API_KEY — leave unset so AAD is the only auth path exercised.
