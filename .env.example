# p2m uses LiteLLM for model calls. Set the env vars for your provider.
# See https://docs.litellm.ai/docs/providers for the full list.

# Azure OpenAI (for model strings like azure/gpt-5.4)
AZURE_API_KEY=
AZURE_API_BASE=https://your-resource.openai.azure.com/

# Per-region endpoints (used by examples/telecom_tau2_correlation)
# AZURE_API_KEY_WESTUS2=
# AZURE_API_BASE_WESTUS2=https://your-westus2-resource.openai.azure.com/
# AZURE_API_KEY_AUSTRALIAEAST=
# AZURE_API_BASE_AUSTRALIAEAST=https://your-australiaeast-resource.openai.azure.com/

# tau2-bench data directory (defaults to examples/telecom_tau2_correlation/data/)
# TAU2_DATA_DIR=/path/to/tau3-bench/data

# OpenAI (for model strings like openai/gpt-4o)
# OPENAI_API_KEY=

# Anthropic (for model strings like anthropic/claude-3.5-sonnet)
# ANTHROPIC_API_KEY=
