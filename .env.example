# ASSERT uses LiteLLM for model calls. Set the env vars for your provider.
# See https://docs.litellm.ai/docs/providers for the full list.

# Azure OpenAI (for model strings like azure/gpt-4o)
AZURE_API_KEY=
AZURE_API_BASE=https://your-resource.openai.azure.com/
# Optional: the viewer wizard reads deployment / model names from these.
# When none are set the model dropdown is empty and the user types a model
# string manually. Bare Azure deployment names are normalized to LiteLLM
# strings as azure/<deployment>.
# AZURE_OPENAI_DEPLOYMENT=your-deployment-name

# --- Optional: Managed Identity / Entra ID auth for Azure OpenAI ---
# Use this instead of (or alongside) AZURE_API_KEY when running on Azure
# infrastructure that has a managed identity, or locally with `az login`.
# Requires the `azure-aad` extra:  pip install -e ".[azure-aad]"
# The caller identity needs the "Cognitive Services OpenAI User" role on
# the target Azure OpenAI resource.
#
# Force AAD even when AZURE_API_KEY is also set (explicit opt-in):
# ASSERT_AZURE_USE_AAD=1
# Pin a specific user-assigned managed identity (otherwise DefaultAzureCredential
# probes its full chain — env vars, MI, az login, etc.):
# AZURE_CLIENT_ID=00000000-0000-0000-0000-000000000000

# OpenAI (for model strings like openai/gpt-4o)
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o

# Anthropic (for model strings like anthropic/claude-3.5-sonnet)
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# Explicit allowlist for the viewer model dropdowns. Comma- or newline-separated.
# Each value may be a bare model name or a full LiteLLM provider/model string.
# ASSERT_MODEL_OPTIONS=azure/your-deployment,openai/gpt-4o,anthropic/claude-3-5-sonnet-latest
# ASSERT_DEFAULT_MODEL=azure/your-deployment
